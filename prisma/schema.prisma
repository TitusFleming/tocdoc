generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role
  createdAt DateTime @default(now())

  events       Event[]       @relation("DoctorEvents")
  ccForDoctors CcRecipient[] @relation("CcUser")
  ccRecipients CcRecipient[] @relation("DoctorCcList")
}

model CcRecipient {
  id       String @id @default(cuid())
  doctorId String
  userId   String

  doctor User @relation("DoctorCcList", fields: [doctorId], references: [id], onDelete: Cascade)
  user   User @relation("CcUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([doctorId, userId])
}

model Event {
  id             String      @id @default(cuid())
  doctorId       String
  patientAlias   String
  dobMonthYear   String?
  diagnosis      String
  hospitalName   String
  status         EventStatus @default(ADMITTED)
  admissionDate  DateTime
  admissionTime  String?
  dischargeDate  DateTime?
  dischargeTime  String?
  dischargeNotes String?
  reviewed       Boolean     @default(false)
  createdAt      DateTime    @default(now())

  doctor User         @relation("DoctorEvents", fields: [doctorId], references: [id])
  images EventImage[]

  @@index([doctorId])
  @@index([patientAlias, status])
  @@index([status])
}

model EventImage {
  id        String   @id @default(cuid())
  eventId   String
  data      Bytes
  filename  String?
  mimeType  String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  DOCTOR
}

enum EventStatus {
  ADMITTED
  DISCHARGED
}
