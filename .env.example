# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth-redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth-redirect

# Database (Neon Postgres recommended)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/tocdoc?sslmode=require

# Email Notifications (Resend)
RESEND_API_KEY=re_xxxxx

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@tocdoc.com

# App URL (for email links)
NEXT_PUBLIC_APP_URL=https://tocdoctor.com
