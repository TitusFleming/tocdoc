# Clerk Authentication (use your own keys from dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth-redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth-redirect

# Database (Neon Postgres recommended)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Email Notifications (Resend)
RESEND_API_KEY=re_your_api_key

# Admin emails (comma-separated). REQUIRED: with no value, nobody gets admin access.
ADMIN_EMAILS=

# App URL (for email links)
NEXT_PUBLIC_APP_URL=https://tocdoctor.com

# Secret for the Vercel Cron retention job (generate any long random string)
CRON_SECRET=
